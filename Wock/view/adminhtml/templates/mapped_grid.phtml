<?php
/**
 * @var \DigitalWarehouse\Wock\Block\Adminhtml\Mapped\Grid $block
 * @var \Magento\Framework\Escaper $escaper
 */
$products = $block->getMappedProducts();
?>

<div class="admin__data-grid-wrap">
    <?php if ($products->getSize() > 0): ?>
        <table class="data-grid">
            <thead>
                <tr>
                    <th class="data-grid-th"><span><?= $escaper->escapeHtml(__('Magento Product ID')) ?></span></th>
                    <th class="data-grid-th"><span><?= $escaper->escapeHtml(__('Magento Name')) ?></span></th>
                    <th class="data-grid-th"><span><?= $escaper->escapeHtml(__('WoCK Product ID')) ?></span></th>
                    <th class="data-grid-th"><span><?= $escaper->escapeHtml(__('WoCK Platform')) ?></span></th>
                    <th class="data-grid-th"><span><?= $escaper->escapeHtml(__('Action')) ?></span></th>
                </tr>
            </thead>
            <tbody>
                <?php foreach ($products as $item): ?>
                    <tr class="data-row">
                        <td><?= $escaper->escapeHtml($item->getId()) ?></td>
                        <td><?= $escaper->escapeHtml($item->getName()) ?></td>
                        <td><strong><?= $escaper->escapeHtml($item->getData('wock_product_id')) ?></strong></td>
                        <td><?= $escaper->escapeHtml($item->getData('wock_platform') ?: '—') ?></td>
                        <td>
                            <a href="<?= $escaper->escapeUrl($block->getUrl('catalog/product/edit', ['id' => $item->getId()])) ?>" class="action-menu-item">
                                <?= $escaper->escapeHtml(__('Edit')) ?>
                            </a>
                        </td>
                    </tr>
                <?php endforeach; ?>
            </tbody>
        </table>
    <?php else: ?>
        <div class="message info empty">
            <span><?= $escaper->escapeHtml(__('There are currently no Magento products mapped to WoCK.')) ?></span>
        </div>
    <?php endif; ?>
</div>

<style>
