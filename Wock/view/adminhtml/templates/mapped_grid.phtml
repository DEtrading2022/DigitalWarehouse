.admin__data-grid-wrap th, .admin__data-grid-wrap th span { background: #f8f8f8; padding: 1.2rem 1rem; text-align: left; border-bottom: 2px solid #ccc; font-weight: 600; color: #000000 !important; }
.admin__data-grid-wrap td { padding: 1rem; border-bottom: 1px solid #e3e3e3; vertical-align: middle; color: #000000 !important; }
.admin__data-grid-wrap tr:hover td { background-color: #f5f5f5; }
.admin__data-grid-wrap .empty { padding: 2rem; }
.admin__data-grid-wrap .action-menu-item { color: #007bdb; text-decoration: none; font-weight: 600; }
.admin__data-grid-wrap .action-menu-item:hover { text-decoration: underline; color: #00599d; }
</style>
