<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- ── Dedicated logger: writes to var/log/wock.log ── -->
    <!-- Uses <type> (not virtualType) because Helper\Logger is a real class -->
    <type name="DigitalWarehouse\Wock\Helper\Logger">
        <arguments>
            <argument name="name" xsi:type="string">WoCK</argument>
            <argument name="handlers" xsi:type="array">
                <item name="default" xsi:type="object">DigitalWarehouse\Wock\Helper\LogHandler</item>
            </argument>
        </arguments>
    </type>

    <!-- ── Service interfaces ── -->
    <preference for="DigitalWarehouse\Wock\Api\TokenManagerInterface"
                type="DigitalWarehouse\Wock\Model\Token\Manager"/>
    <preference for="DigitalWarehouse\Wock\Api\ProductServiceInterface"
                type="DigitalWarehouse\Wock\Model\Api\ProductService"/>
    <preference for="DigitalWarehouse\Wock\Api\OrderServiceInterface"
                type="DigitalWarehouse\Wock\Model\Api\OrderService"/>
    <preference for="DigitalWarehouse\Wock\Api\DeliveryServiceInterface"
                type="DigitalWarehouse\Wock\Model\Api\DeliveryService"/>
    <preference for="DigitalWarehouse\Wock\Api\PartnerServiceInterface"
                type="DigitalWarehouse\Wock\Model\Api\PartnerService"/>

    <!-- ── Inject WoCK logger + dependencies into all key classes ── -->
    <type name="DigitalWarehouse\Wock\Model\Token\Manager">
        <arguments>
            <argument name="logger" xsi:type="object">DigitalWarehouse\Wock\Helper\Logger</argument>
            <argument name="curlFactory" xsi:type="object">Magento\Framework\HTTP\Client\CurlFactory</argument>
        </arguments>
    </type>
    <type name="DigitalWarehouse\Wock\Model\Api\Client">
        <arguments>
            <argument name="logger" xsi:type="object">DigitalWarehouse\Wock\Helper\Logger</argument>
            <argument name="curlFactory" xsi:type="object">Magento\Framework\HTTP\Client\CurlFactory</argument>
        </arguments>
    </type>
    <type name="DigitalWarehouse\Wock\Controller\Webhook\Product">
        <arguments>
            <argument name="logger" xsi:type="object">DigitalWarehouse\Wock\Helper\Logger</argument>
        </arguments>
    </type>
    <type name="DigitalWarehouse\Wock\Controller\Webhook\Delivery">
        <arguments>
            <argument name="logger" xsi:type="object">DigitalWarehouse\Wock\Helper\Logger</argument>
        </arguments>
    </type>
    <type name="DigitalWarehouse\Wock\Observer\ProductWebhookObserver">
        <arguments>
            <argument name="logger" xsi:type="object">DigitalWarehouse\Wock\Helper\Logger</argument>
            <argument name="syncLog" xsi:type="object">DigitalWarehouse\Wock\Model\SyncLog</argument>
        </arguments>
    </type>
    <type name="DigitalWarehouse\Wock\Observer\DeliveryWebhookObserver">
        <arguments>
            <argument name="logger" xsi:type="object">DigitalWarehouse\Wock\Helper\Logger</argument>
            <argument name="syncLog" xsi:type="object">DigitalWarehouse\Wock\Model\SyncLog</argument>
            <argument name="orderMap" xsi:type="object">DigitalWarehouse\Wock\Model\OrderMap</argument>
        </arguments>
    </type>
    <type name="DigitalWarehouse\Wock\Observer\ProductSaveBefore">
        <arguments>
            <argument name="logger" xsi:type="object">DigitalWarehouse\Wock\Helper\Logger</argument>
        </arguments>
    </type>
    <type name="DigitalWarehouse\Wock\Observer\OrderPlaceAfter">
        <arguments>
            <argument name="logger" xsi:type="object">DigitalWarehouse\Wock\Helper\Logger</argument>
        </arguments>
    </type>
    <type name="DigitalWarehouse\Wock\Observer\OrderStatusChange">
        <arguments>
            <argument name="logger" xsi:type="object">DigitalWarehouse\Wock\Helper\Logger</argument>
        </arguments>
    </type>
    <type name="DigitalWarehouse\Wock\Cron\SyncProducts">
        <arguments>
            <argument name="logger" xsi:type="object">DigitalWarehouse\Wock\Helper\Logger</argument>
            <argument name="syncLog" xsi:type="object">DigitalWarehouse\Wock\Model\SyncLog</argument>
        </arguments>
    </type>
    <type name="DigitalWarehouse\Wock\Cron\SyncOrders">
        <arguments>
            <argument name="logger" xsi:type="object">DigitalWarehouse\Wock\Helper\Logger</argument>
            <argument name="syncLog" xsi:type="object">DigitalWarehouse\Wock\Model\SyncLog</argument>
            <argument name="orderMap" xsi:type="object">DigitalWarehouse\Wock\Model\OrderMap</argument>
        </arguments>
    </type>

    <!-- ── OrderBuilder must be non-shared to prevent stale state ── -->
    <type name="DigitalWarehouse\Wock\Helper\OrderBuilder" shared="false"/>

    <!-- ── Webhook cache bypass plugin ── -->
    <type name="Magento\Framework\App\FrontControllerInterface">
        <plugin name="wock_webhook_not_cacheable"
                type="DigitalWarehouse\Wock\Plugin\NotCacheableWebhookPlugin"/>
    </type>

    <!-- ── Console commands ── -->
    <type name="Magento\Framework\Console\CommandList">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="wock_sync_products"   xsi:type="object">DigitalWarehouse\Wock\Console\Command\SyncProducts</item>
                <item name="wock_sync_orders"     xsi:type="object">DigitalWarehouse\Wock\Console\Command\SyncOrders</item>
                <item name="wock_test_connection" xsi:type="object">DigitalWarehouse\Wock\Console\Command\TestConnection</item>
            </argument>
        </arguments>
    </type>

</config>
